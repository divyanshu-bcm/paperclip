# ─── Database ───────────────────────────────────────────────
# Railway provides this via the Postgres plugin, or set manually.
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# ─── Server ────────────────────────────────────────────────
# Railway sets PORT automatically — do not hardcode in Railway dashboard.
PORT=3100
HOST=0.0.0.0
SERVE_UI=true
NODE_ENV=production

# ─── Deployment ────────────────────────────────────────────
# authenticated = requires login, unauthenticated = open, local_trusted = dev
PAPERCLIP_DEPLOYMENT_MODE=authenticated
# public = internet-facing, private = internal only
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
# Your Railway public domain, e.g. https://your-app.up.railway.app
PAPERCLIP_PUBLIC_URL=

# ─── Authentication (required for authenticated mode) ──────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ─── Migrations ────────────────────────────────────────────
# Auto-apply database migrations on startup (recommended for Railway)
PAPERCLIP_MIGRATION_AUTO_APPLY=true

# ─── API Keys (optional, add as needed) ───────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GITHUB_TOKEN=
